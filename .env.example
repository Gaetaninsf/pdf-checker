# Copy to .env or .env.local only if you need overrides.
# Never paste real secrets into AI chat or commit them to git.

APP_ENV=local

# Identity used in local/test when the X-Goog-Authenticated-User-Email header
# is absent. Ignored in production — IAP sets the header on every request.
DEV_USER_EMAIL=dev.user@example.com

# Box API credentials (CCG auth for production).
# In production these come from GCP Secret Manager.
# For local dev, set BOX_DEVELOPER_TOKEN in .env.local instead.
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
BOX_FOLDER_ID=

# Optional: static token for local testing only.
BOX_DEVELOPER_TOKEN=
BOX_ACCESS_TOKEN=
